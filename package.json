{
	"name": "template-full-stack",
	"private": true,
	"description": "Full Stack Template demonstrating coding patterns and full stack model from Customware AI",
	"type": "module",
	"scripts": {
		"build:client": "react-router build",
		"build:server": "tsc --project server/tsconfig.json",
		"build": "pnpm run build:client && pnpm run build:server",
		"start": "node build/server/start.js",
		"typegen": "react-router typegen",
		"typecheck": "react-router typegen && tsc && tsc --project server/tsconfig.json",
		"lint": "oxlint --type-aware .",
		"test": "vitest run",
		"check": "pnpm run typecheck && pnpm run lint",
		"e2e:install": "playwright install",
		"e2e": "pnpm run build && playwright test",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx server/db/migrate.ts"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.5",
		"@hono/trpc-server": "^0.4.2",
		"@hookform/resolvers": "5.4.0",
		"@react-router/node": "7.18.0",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-table": "8.21.3",
		"@trpc/client": "^11.17.0",
		"@trpc/react-query": "^11.17.0",
		"@trpc/server": "^11.17.0",
		"better-sqlite3": "^12.11.1",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"date-fns": "4.4.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"hono": "^4.12.25",
		"input-otp": "1.4.2",
		"isbot": "5.1.43",
		"lucide-react": "1.20.0",
		"neverthrow": "8.2.0",
		"next-themes": "^0.4.6",
		"radix-ui": "1.6.0",
		"react": "19.2.7",
		"react-day-picker": "10.0.1",
		"react-dom": "19.2.7",
		"react-hook-form": "7.79.0",
		"react-is": "19.2.7",
		"react-resizable-panels": "4.11.2",
		"react-router": "7.18.0",
		"recharts": "3.8.1",
		"sonner": "2.0.7",
		"tailwind-merge": "3.6.0",
		"tailwindcss-animate": "1.0.7",
		"vaul": "1.1.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@playwright/test": "1.59.1",
		"@react-router/dev": "7.18.0",
		"@rolldown/plugin-babel": "0.2.3",
		"@tailwindcss/vite": "4.3.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
